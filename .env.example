# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bodecart?schema=public"
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-secret-in-production-use-strong-random-string"
JWT_EXPIRATION="1h"
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production"
JWT_REFRESH_EXPIRATION="7d"

# Maps Configuration (OpenStreetMap)
# Photon API: https://photon.komoot.io (no API key required)
# OSRM API: https://router.project-osrm.org (no API key required)
# Note: For production, consider self-hosting or using rate-limited alternatives

# Stripe
# Get your keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# PayPal
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_SECRET="your-paypal-secret"
PAYPAL_MODE="sandbox"

# AWS S3
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="bodecart-images"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"

# Firebase
FIREBASE_PROJECT_ID="bodecart-xxxxx"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@bodecart.iam.gserviceaccount.com"

# App Configuration
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Email Configuration (for OTP verification)
# ============================================
# IMPORTANT: Set ENABLE_EMAIL_VERIFICATION=false for local development if you don't want to configure email
# When disabled, OTP codes will be logged to the console instead of being sent via email
ENABLE_EMAIL_VERIFICATION=false

# Gmail SMTP Configuration
# ========================
# To use Gmail for sending emails, you MUST:
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an "App Password" (NOT your regular Gmail password)
# 3. Use the App Password in SMTP_PASSWORD
#
# How to generate Gmail App Password:
# 1. Go to: https://myaccount.google.com/security
# 2. Enable "2-Step Verification" if not already enabled
# 3. Go to: https://myaccount.google.com/apppasswords
# 4. Select "Mail" and "Other (Custom name)" → Enter "BodeCart"
# 5. Click "Generate" and copy the 16-character password
# 6. Paste it in SMTP_PASSWORD below (remove spaces)
#
# For detailed instructions with screenshots, see: backend/EMAIL_SETUP.md
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-character-app-password

# Alternative email providers:
# ============================
# Outlook/Hotmail:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#
# Yahoo Mail:
#   SMTP_HOST=smtp.mail.yahoo.com
#   SMTP_PORT=587
#
# SendGrid (recommended for production):
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASSWORD=your-sendgrid-api-key

# Google Sign-In
# Get your Web Client ID from: https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID of type "Web Application"
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Sentry (Optional - for error tracking)
SENTRY_DSN=your-sentry-dsn
